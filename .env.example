# Copy to .env.local and fill in what you use. Every tool works independently —
# you only need the variables for the tools you run.

# ── perf-audit (optional enrichments) ────────────────────────────────────────
# Google PageSpeed Insights API key → real CrUX field data (incl. INP) + Lighthouse.
# Free: https://developers.google.com/speed/docs/insights/v5/get-started
PSI_API_KEY=

# Backlink data needs a paid provider (no free source exists).
#BACKLINKS_PROVIDER=ahrefs
SEMRUSH_API_KEY=
#AHREFS_API_TOKEN=

# ── gsc-fetch (Google Search Console) ────────────────────────────────────────
# Property exactly as it appears in GSC:
#   domain property  → sc-domain:example.com
#   URL-prefix       → https://www.example.com/
GSC_SITE_URL=

# Auth, option A (recommended): OAuth as yourself — create a "Desktop app" OAuth
# client in Google Cloud Console, then run `npm run gsc:auth` once to mint the
# refresh token (it appends GSC_OAUTH_REFRESH_TOKEN here).
GSC_OAUTH_CLIENT_ID=
GSC_OAUTH_CLIENT_SECRET=
#GSC_OAUTH_REFRESH_TOKEN=

# Auth, option B: service-account JSON key (add its client_email as a GSC user).
#GSC_SA_KEY=/path/outside/the/repo/key.json

# ── umami-fetch (self-hosted Umami v3) ───────────────────────────────────────
UMAMI_API_URL=
UMAMI_WEBSITE_ID=
UMAMI_USERNAME=
UMAMI_PASSWORD=
# Optional: subtract known datacenter/bot countries as an "adjusted" totals row
#UMAMI_DC_COUNTRIES=SG,HK
# Optional: referrer hosts to classify as "internal" (your own domains)
#UMAMI_INTERNAL_HOSTS=example.com,auth.example.com
